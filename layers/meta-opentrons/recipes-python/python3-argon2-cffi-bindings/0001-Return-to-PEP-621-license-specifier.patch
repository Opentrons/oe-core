From: Seth Foster <seth@opentrons.com>
Date: Fri, 6 Mar 2026 15:18:43 -0500
Subject: [PATCH] Return to PEP-621 license specifier

---
 pyproject.toml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index 5e374f6..e0f87e5 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -15,8 +15,6 @@ description = "Low-level CFFI bindings for Argon2"
 readme = { content-type = "text/markdown", file = "README.md" }
 authors = [{ name = "Hynek Schlawack", email = "hs@ox.cx" }]
 requires-python = ">=3.9"
-license = "MIT"
-license-files = ["LICENSE"]
 keywords = ["password", "hash", "hashing", "security", "bindings", "cffi"]
 classifiers = [
     "Development Status :: 5 - Production/Stable",
@@ -48,6 +46,8 @@ dependencies = [
 tests = ["pytest"]
 dev = [{ include-group = "tests" }, "cogapp", "pre-commit"]
 
+[project.license]
+file = "LICENSE"
 
 [project.urls]
 Tidelift = "https://tidelift.com/?utm_source=lifter&utm_medium=referral&utm_campaign=hynek"
-- 
